# Environment for templates/wordpress.compose.yml.
#
# You normally do NOT need to set anything here. Every variable the compose file
# uses has the SERVICE_ prefix, which Dokploy auto-generates (random, per-service)
# on deploy. They are listed only to document their purpose — leave them blank and
# let Dokploy populate them. The domain is NOT set here; wire it in Dokploy's
# Domain tab after the site is created and restored.

SERVICE_USER_WORDPRESS=
SERVICE_PASSWORD_WORDPRESS=
SERVICE_PASSWORD_ROOT=
